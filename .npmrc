# Puppeteer 5 cannot download Chromium for arm64 during postinstall; skip bundled Chrome.
# Use system Chrome or puppeteer-core with executablePath if you need PDF/screenshot features locally.
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# date-fns v3 vs @mui/x-date-pickers peer (date-fns v2); lockfile resolves with this on npm 10+
legacy-peer-deps=true
